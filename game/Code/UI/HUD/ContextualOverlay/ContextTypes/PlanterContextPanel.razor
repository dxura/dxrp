@namespace Dxura.RP.Game.UI
@using Dxura.RP.Game.Entities
@inherits BaseContextPanel

<root>
	<div class="flex flex-col items-center justify-center rounded bg-primary-75 p-3">
		<span class="text-accent text-xl mb-2">#planter.title</span>
		
		@if(!Planter.Soiled || !Planter.Watered || !Planter.HasLight)
		{
			<!-- Requirements Progress -->
			<div class="flex items-center gap-3 mb-2">
				<div class="flex items-center gap-1">
					<span class="@(Planter.Soiled ? "text-good" : "text-bad")">
						@(Planter.Soiled ? "✅" : "❌")
					</span>
					<span class="text-sm">#planter.soil</span>
				</div>
			
				<div class="flex items-center gap-1">
					<span class="@(Planter.Watered ? "text-good" : "text-bad")">
						@(Planter.Watered ? "✅" : "❌")
					</span>
					<span class="text-sm">#planter.water</span>
				</div>
			
				<div class="flex items-center gap-1">
					<span class="@(Planter.HasLight ? "text-good" : "text-bad")">
						@(Planter.HasLight ? "✅" : "❌")
					</span>
					<span class="text-sm">#planter.light</span>
				</div>
			</div>
		}
		
		<!-- Plant Information (Compact) -->
		@if (Planter.Plant != null)
		{
			<div class="flex items-center gap-2 mb-2">
				@if (Planter.Plant.Resource.Icon != null)
				{
					<Icon File="@Planter.Plant.Resource.Icon.ResourcePath" size="40"/>
				}

			</div>
			
			@if (!Planter.IsMature)
			{
				<div class="flex items-center gap-2 text-sm">
					<span class="text-gray-400">@string.Format( Language.GetPhrase( "planter.stage" ), Planter.Stage, Planter.Plant.Stages.Count )</span>
					<span class="text-gray-400">(@(Math.Round(Planter.TotalGrowthPercentage, 0))%)</span>
				</div>
			}
		}

		<!-- Current Status -->
		@if ( Planter.Plant == null || !Planter.Soiled || !Planter.HasLight || !Planter.Watered || Planter.IsMature )
		{
			<div class="flex items-center gap-2 mb-2 bg-primary p-2 rounded">
				@if (!Planter.Soiled)
				{
					<span>@($"🌳 {Language.GetPhrase( "planter.add_soil" )}")</span>
				}
				else if (!Planter.Watered)
				{
					<span>@($"💧 {Language.GetPhrase( "planter.needs_watering" )}")</span>
				}
				else if (!Planter.HasLight)
				{
					<span>@($"☀️ {Language.GetPhrase( "planter.needs_light" )}")</span>
				}
				else if (Planter.IsMature)
				{
					<span>@($"🌿 {Language.GetPhrase( "planter.ready_to_harvest" )}")</span>
				}
				else
				{
					<span>#planter.sow_seed</span>
				}
			</div>
		}
	</div>
</root>

@code {
	protected override int BuildHash()
	{
		return HashCode.Combine( Planter.Soiled, Planter.HasLight, Planter.Watered, Planter.Plant, Planter.Stage, Planter.GrowthProgress, Planter.IsMature );
	}

	private PlanterEntity Planter => (Context.Object as PlanterEntity)!;
}
