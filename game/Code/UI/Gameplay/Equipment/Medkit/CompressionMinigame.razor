@namespace Dxura.RP.Game.UI
@inherits Panel
@attribute [StyleSheet]


<root
	class="absolute left-1/2 -translate-x-1/2 -translate-y-1/2 p-2 px-4 bg-black-50 flex items-center justify-center flex-col gap-2 rounded @BuildClass()"
	style="top: 75%">
	
	@if ( !IsActive ) return;

	<label class="emphasis text-base text-bold">@Status</label>

	<div class="compression-track" style="position: relative; height: 20px; width: 350px; background-color: rgba(255, 255, 255, 0.1); border-radius: 4px; margin: 15px 0; overflow: hidden; border: 2px solid rgba(255, 255, 255, 0.3);">
		<div class="track-background" style="position: absolute; top: 5px; left: 0; bottom: 5px; width: @(GetLifeline())%; background-image: linear-gradient(90deg, rgba(255, 50, 50, 0.6) 0%, rgba(255, 50, 50, 0.8) 50%, rgba(255, 50, 50, 0.6) 100%); transition: width 0.1s ease-out; border-radius: 2px;"></div>

		<div class="success-zone" style="position: absolute; top: 0px; bottom: 0px; left: @( CurrentSuccessZone.Start )%; width: @( CurrentSuccessZone.Width )%; background-color: #00FF00; border-radius: 2px;"></div>

		<div class="compression-indicator" style="position: absolute; top: -2px; bottom: -2px; left: @( IndicatorPosition )%; width: 3px; background-color: #ffffff; border-radius: 1px; box-shadow: 0 0 8px rgba(255, 255, 255, 1);">
		</div>
	</div>

	<div style="display: flex; justify-content: center; align-items: center; gap: 30px; width: 100%; margin-bottom: 5px;">
		<div class="text-good text-lg font-bold">@string.Format( Language.GetPhrase( "compression.perfect_progress" ), PerfectHits, RequiredHits )</div>
		<div class="text-bad text-lg font-bold">@( $"{TimeRemaining:F1}s" )</div>
	</div>

	<div class="flex w-full justify-between">
		<div class="text-sm flex gap-2 items-center justify-center">
			<span>@Language.GetPhrase( "compression.hold" )</span>
			<InputHint Action="attack1" class="small" Size="@InputGlyphSize.Small" Animate="@false"/>
		</div>
		<div class="text-sm flex gap-2 items-center justify-center">
			<span>@Language.GetPhrase( "compression.press" )</span>
			<InputHint Action="attack2" class="small" Size="@InputGlyphSize.Small" Animate="@false"/>
		</div>
	</div>

	@if ( LastHitResult != HitResult.None && ShowHitFeedback )
	{
		<div class="hit-feedback @GetHitClass()" style="position: absolute; top: 25%; left: 50%; transform: translate(-50%, -50%); font-size: 28px; font-weight: bold; text-shadow: 2px 2px 6px rgba(0, 0, 0, 0.8); pointer-events: none; animation: hit-popup 1s ease-out; z-index: 10;">
			@GetHitText()
		</div>
	}
</root>

@code
{
	public class SuccessZone
	{
		public float Start { get; set; }
		public float Width { get; set; }
	}

	public enum HitResult
	{
		None,
		Miss,
		Perfect
	}

	public enum FailReason
	{
		None,
		OutOfTime,
		ButtonReleased,
		MissedCompression,
		MovedTooFar,
		TargetRespawned
	}

	public static CompressionMinigame Instance { get; set; } = null!;

	private string Status { get; set; } = "";
	private bool IsActive { get; set; }
	private float TimeRemaining { get; set; } = 6f;
	private float IndicatorPosition { get; set; } = 0f;
	private int PerfectHits { get; set; } = 0;
	private int RequiredHits { get; set; } = 0;
	private HitResult LastHitResult { get; set; } = HitResult.None;
	private bool ShowHitFeedback { get; set; } = false;
	
	private Player? TargetPlayer { get; set; }
	private bool IsReviving { get; set; } = false;
	
	public SuccessZone CurrentSuccessZone { get; set; } = new();
	
	private const float DefaultIndicatorSpeed = 100f;
	private float _indicatorSpeed = DefaultIndicatorSpeed;
	private bool _movingRight = true;
	private TimeSince _lastHitTime = 0;
	private TimeSince _gameStartTime = 0;
	private float _gameTimeLimit = 6f;
	private Queue<float> _recentFrameTimes = new();
	private const int FrameHistorySize = 15;
	private float _smoothedDeltaTime = 1f / 60f;

	// Movement boundaries
	private const float IndicatorMinPosition = 3f;
	private const float IndicatorMaxPosition = 97f;
	
	public Action<bool, FailReason>? OnMinigameComplete { get; set; }
	public Action<HitResult>? OnCompressionAttempt { get; set; }
	
	public CompressionMinigame()
	{
		Instance = this;
		GenerateNewSuccessZone();
	}
	
	public void StartMinigame( string status, int? requiredHits = null, float? timeLimit = null, Player? targetPlayer = null, bool isReviving = false )
	{
		Status = status;
		RequiredHits = requiredHits ?? Config.Current.Game.ReviveRequiredHits;
		var actualTimeLimit = timeLimit ?? Config.Current.Game.ReviveTimeLimit;
		TimeRemaining = actualTimeLimit;
		_gameTimeLimit = actualTimeLimit;
		PerfectHits = 0;
		IsActive = true;
		IndicatorPosition = 0f;
		_movingRight = true;
		_gameStartTime = 0;
		LastHitResult = HitResult.None;
		ShowHitFeedback = false;
		_recentFrameTimes.Clear();
		_smoothedDeltaTime = 1f / 60f;
		_indicatorSpeed = Config.Current.Game.ReviveIndicatorSpeed;
		
		TargetPlayer = targetPlayer;
		IsReviving = isReviving;
		
		GenerateNewSuccessZone();
		StateHasChanged();
	}
	
	public void StopMinigame()
	{
		IsActive = false;
		LastHitResult = HitResult.None;
		ShowHitFeedback = false;
		TargetPlayer = null;
		IsReviving = false;
		StateHasChanged();
	}

	public override void Tick()
	{
		if ( IsActive )
		{
			UpdateMinigame();
		}
	}

	protected override int BuildHash()
	{
		return HashCode.Combine( Status, IsActive, TimeRemaining, IndicatorPosition, PerfectHits, LastHitResult, ShowHitFeedback, CurrentSuccessZone.Start );
	}
	
	private void UpdateMinigame()
	{
		if ( !IsActive ) return;

		var elapsed = _gameStartTime;
		TimeRemaining = _gameTimeLimit - elapsed;

		if ( TimeRemaining <= 0 )
		{
			OnMinigameComplete?.Invoke( false, FailReason.OutOfTime );
			StopMinigame();
			return;
		}

		UpdateFrameTracking();

		var deltaMove = _indicatorSpeed * _smoothedDeltaTime;
		if ( _movingRight )
		{
			IndicatorPosition += deltaMove;
			if ( IndicatorPosition >= IndicatorMaxPosition )
			{
				IndicatorPosition = IndicatorMaxPosition;
				_movingRight = false;
			}
		}
		else
		{
			IndicatorPosition -= deltaMove;
			if ( IndicatorPosition <= IndicatorMinPosition )
			{
				IndicatorPosition = IndicatorMinPosition;
				_movingRight = true;
			}
		}

		if ( _lastHitTime > 0.5f )
		{
			ShowHitFeedback = false;
			LastHitResult = HitResult.None;
		}
	}

	private void UpdateFrameTracking()
	{
		_recentFrameTimes.Enqueue( Time.Delta );

		if ( _recentFrameTimes.Count > FrameHistorySize )
		{
			_recentFrameTimes.Dequeue();
		}

		if ( _recentFrameTimes.Count > 0 )
		{
			var averageDelta = _recentFrameTimes.Average();

			averageDelta = MathX.Clamp( averageDelta, 1f / 300f, 1f / 5f );

			_smoothedDeltaTime = MathX.Lerp( _smoothedDeltaTime, averageDelta, Config.Current.Game.ReviveIndicatorSmoothingFactor );
		}
	}
	
	private void GenerateNewSuccessZone()
	{
		var random = new Random();
		float start;
		
		do
		{
			start = random.Next( Config.Current.Game.ReviveZoneMinStartPosition, Config.Current.Game.ReviveZoneMaxStartPosition );
		}
		while ( Math.Abs( start - IndicatorPosition ) < Config.Current.Game.ReviveZoneMinDistance );
		
		var width = random.Next( Config.Current.Game.ReviveZoneMinWidth, Config.Current.Game.ReviveZoneMaxWidth );
		
		CurrentSuccessZone = new SuccessZone 
		{ 
			Start = start, 
			Width = width
		};
	}
	
	public void TriggerCompression()
	{
		if ( !IsActive ) return;
		
		AttemptCompression();
	}
	
	private void AttemptCompression()
	{
		_lastHitTime = 0;
		
		var hitResult = HitResult.Miss;
		var zoneStart = CurrentSuccessZone.Start;
		var zoneEnd = CurrentSuccessZone.Start + CurrentSuccessZone.Width;
		
		var tolerance = Config.Current.Game.ReviveTolerance;
		var adjustedZoneStart = zoneStart - tolerance;
		var adjustedZoneEnd = zoneEnd + tolerance;
		
		if ( IndicatorPosition >= adjustedZoneStart && IndicatorPosition <= adjustedZoneEnd )
		{
			hitResult = HitResult.Perfect;
			PerfectHits++;
		}
		
		LastHitResult = hitResult;

		ShowHitFeedback = false;
		StateHasChanged();
		ShowHitFeedback = true;

		OnCompressionAttempt?.Invoke( hitResult );
		
		GenerateNewSuccessZone();
		
		if ( PerfectHits >= RequiredHits )
		{
			OnMinigameComplete?.Invoke( true, FailReason.None );
			StopMinigame();
		}
		else if ( hitResult == HitResult.Miss )
		{
			OnMinigameComplete?.Invoke( false, FailReason.MissedCompression );
			StopMinigame();
		}
	}
	
	private string GetHitClass()
	{
		return LastHitResult switch
		{
			HitResult.Perfect => "perfect",
			HitResult.Miss => "miss",
			_ => ""
		};
	}
	
	private string GetHitText()
	{
		return LastHitResult switch
		{
			HitResult.Perfect => Language.GetPhrase( "compression.perfect_hit" ),
			HitResult.Miss => Language.GetPhrase( "compression.miss_hit" ),
			_ => ""
		};
	}
	
	private float GetLifeline()
	{
		if ( TargetPlayer?.IsValid() != true )
			return 100f;

		var respawnTimeLimit = Config.Current.Game.RespawnTime;

		if ( respawnTimeLimit <= 0 )
			return 0f;

		var elapsedTime = TargetPlayer.GetEffectiveRespawnElapsed();
		var remainingTime = Math.Max( 0f, respawnTimeLimit - elapsedTime );
		return Math.Max( 0f, (remainingTime / respawnTimeLimit) * 100f );
	}
	
	private string BuildClass()
	{
		return IsActive ? "visible" : "hidden";
	}
}
