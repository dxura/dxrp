@namespace Dxura.RP.Game.UI
@inherits Panel

<root>
	<div class="flex flex-col bg-secondary-35 rounded-lg p-4 overflow-y-scroll w-full">
		<div class="flex flex-col gap-4">
			<div class="flex flex-col">
				<h2 class="text-xl text-accent mb-2">#credits.models</h2>
				<p class="text-gray-400 mb-2">#credits.models.license</p>
				<ul class="flex flex-col gap-2">
					@foreach ( var item in ModelCredits )
					{
						<li class="text-tertiary p-2 rounded">@Language.GetPhrase( item.Key ) <a class="text-accent cursor-pointer ml-2" href="@item.Url">@item.Url</a></li>
					}
				</ul>
			</div>

			<div class="flex flex-col">
				<h2 class="text-xl text-accent mb-2">#credits.maps_assets</h2>
				<ul class="flex flex-col gap-2">
					@foreach ( var key in MapAssetCredits )
					{
						<li class="text-tertiary p-2 rounded">@Language.GetPhrase( key )</li>
					}
				</ul>
			</div>			
			
			<div class="flex flex-col">
				<h2 class="text-xl text-accent mb-2">#credits.sounds</h2>
				<ul class="flex flex-col gap-2">
					@foreach ( var key in SoundCredits )
					{
						<li class="text-tertiary p-2 rounded">@Language.GetPhrase( key )</li>
					}
				</ul>
			</div>

			<div class="flex flex-col">
				<h2 class="text-xl text-accent mb-2">#credits.special_thanks</h2>
				<ul class="flex flex-col gap-2">
					@foreach ( var key in ThanksCredits )
					{
						<li class="text-tertiary p-2 rounded">@Language.GetPhrase( key )</li>
					}
				</ul>
			</div>

			<div class="flex flex-col">
				<h2 class="text-xl text-accent mb-2">#credits.resources</h2>
				<ul class="flex flex-col gap-2">
					@foreach ( var key in ResourceCredits )
					{
						<li class="text-tertiary p-2 rounded">@Language.GetPhrase( key )</li>
					}
				</ul>
			</div>
		</div>
	</div>
</root>

