@namespace Dxura.RP.Game.UI
@using Dxura.RP.Shared
@inherits Sandbox.UI.Navigation.NavigationHost
@attribute [StyleSheet]

<root>
<div class="flex-grow w-full flex flex-col h-full gap-3 overflow-y-scroll overflow-x-hidden">
	@{
		var inFaction = Player.Local.IsInFaction;
		var faction = inFaction ? Player.Local.GetFaction() : null;
	}

	<div class="section-header p-2 px-4 rounded">
		<h1 class="text-2xl">
			@if ( inFaction && faction != null )
			{
				@faction?.Name <span class="text-gray-400">[@faction?.Tag]</span> <span class="text-sm text-gray-400 ml-4">@string.Format( Language.GetPhrase( "faction.tab.level" ), faction?.Level )</span>
			}
			else
			{
				<span>#faction.tab.title</span>
			}
		</h1>
	</div>

	<div class="flex gap-2 px-2">
		@if ( inFaction )
		{
			<button class="btn btn-primary text-bold" href="/tabmenu/faction/overview">#faction.tab.overview</button>
			<button class="btn btn-primary text-bold" href="/tabmenu/faction/members">#faction.tab.members</button>
			<button class="btn btn-primary text-bold" href="/tabmenu/faction/settings">#generic.settings</button>
			<button class="btn btn-primary text-bold" href="/tabmenu/faction/browse">#faction.tab.all</button>
		}
		else
		{
			<button class="btn btn-primary text-bold" href="/tabmenu/faction/browse">#faction.tab.browse</button>
		}
	</div>

	<div class="navigator-body">
		<div class="grow navigator-canvas" slot="navigator-canvas" style="width: 100%; height: 100%;"></div>
	</div>
</div>
</root>

@code {
	public FactionTabMenuSection()
	{
		DefaultUrl = "/tabmenu/faction/browse";
	}

	protected override int BuildHash()
	{
		if ( !FactionSystem.Instance.IsValid() ) return 0;

		return HashCode.Combine(
			Player.Local?.FactionId,
			Player.Local?.FactionRoleId,
			FactionSystem.Instance.Factions.Count,
			FactionSystem.Instance.FactionRoles.Count
		);
	}
}
