@namespace Dxura.RP.Game.UI
@inherits Sandbox.UI.Navigation.NavigationHost
@attribute [StyleSheet]
@page "/settings"

<root style="width: 25vw; height: 80vh">
	<div class="w-full p-2 bg-primary-75 flex items-center justify-center">
		<h1 class="text-accent text-2xl">
			<span>#settings.title</span>
		</h1>
	</div>
	
	<div class="flex gap-2 m-2">
		<button class="btn btn-primary text-bold" href="/settings/general" >#settings.general</button>
		<button class="btn btn-primary text-bold" href="/settings/graphics" >#settings.graphics</button>
		<button class="btn btn-primary text-bold" href="/settings/performance" >#settings.performance</button>
		<button class="btn btn-primary text-bold" href="/settings/audio">#settings.audio</button>
		<button class="btn btn-primary text-bold" href="/settings/miscellaneous">#settings.miscellaneous</button>
	</div>

	<div class="navigator-body">
		<div class="grow navigator-canvas" slot="navigator-canvas" style="width: 100%; height: 100%;"></div>
	</div>
	
	<div class="flex w-full items-center justify-center">
		<div class="bg-gradient-blue text-white text-lg text-sm p-2 rounded m-4 cursor-pointer hover-scale text-bold " 
		     @onclick="@OpenSboxSettings">
			<span>#settings.open_sbox</span>
		</div>
	</div>
	
</root>

@code {
	public Settings()
	{
		DefaultUrl = "/settings/general";
	}
	
	private void OpenSboxSettings()
	{
		Sandbox.Game.Overlay.ShowSettingsModal();
		Sound.Play( "pop" );
	}
}
