@using Sandbox;
@using Sandbox.UI;
@inherits PanelComponent
@namespace Dxura.RP.Game.UI

<root>
	<div class="modal-content shadow-lg rounded-lg">
		<div class="flex flex-col items-center gap-3">
			<div class="title"><span class="text-accent">DX</span><span class="text-white">RP</span></div>
			
			@if (!HasAcceptedPrivacy)
			{
				<div class="subtitle">#consent.privacypolicy</div>

				<div class="flex flex-col items-center w-full">
					<div class="flex flex-col p-8 text-white text-base w-1/3">
						<p class="mb-6">#consent.privacy.recording.disclosure</p>

						<p class="mb-6">#consent.privacy.data.collection.intro</p>
						<ul class="mb-6 flex flex-col gap-2">
							<li>#consent.privacy.data.steam</li>
							<li>#consent.privacy.data.playtime</li>
							<li>#consent.privacy.data.dates</li>
							<li>#consent.privacy.data.activities</li>
							<li>#consent.privacy.data.ip</li>
						</ul>

						<p class="mb-6">#consent.privacy.ai.moderation</p>

						<p class="mb-6">#consent.privacy.data.security</p>

						<p class="mb-6">#consent.privacy.data.media</p>

						<p><span>#consent.privacy.contact.info</span> <span class="text-accent ml-2">#consent.privacy.contact.email</span></p>
					</div>
				</div>

				<div class="flex gap-2 mb-4">
					<button class="btn btn-bad" onclick=@(() => Game.Close())>#consent.no</button>
					<button class="btn btn-good" onclick=@(() => ConfirmPrivacy())>#consent.yes</button>
				</div>
			}
			else
			{
				<div class="subtitle">#consent.rules</div>
				<div class="rules-container">
					<Rules />
				</div>
				<button class="btn btn-good" onclick=@(() => ConfirmRules())>#consent.yes</button>
			}
		</div>
	</div>
</root>

@code
{
	private bool HasAcceptedPrivacy { get; set; }

	private void ConfirmPrivacy()
	{
		_ = PlayerApiClient.Consent();
		HasAcceptedPrivacy = true;
		StateHasChanged();
	}

	private void ConfirmRules()
	{
		Destroy();
	}
}

